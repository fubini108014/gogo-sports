# ─────────────────────────────────────────────────
# GoGo Sports API - Environment Variables
# 複製此檔案為 .env 並填入你的設定值
# ─────────────────────────────────────────────────

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database (PostgreSQL)
# 格式: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/gogosports"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# CORS (前端開發網址)
CORS_ORIGIN="http://localhost:5173"

# LINE Login (用於 LIFF 整合)
# 在 LINE Developers Console 建立 LINE Login channel 後填入
# LINE_CHANNEL_ID=""

# (Optional) Cloudflare R2 / AWS S3 圖片上傳
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""
# R2_PUBLIC_URL=""
