generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum PrimarySport {
  BADMINTON
  VOLLEYBALL
  BASKETBALL
  TABLE_TENNIS
  TENNIS
  PICKLEBALL
  HIKING
  RUNNING
  OTHER
}

enum RegistrationMode {
  LIMITED
  OPEN
}

enum ApprovalMode {
  AUTO
  MANUAL
}

enum ActivityStatus {
  OPEN
  FULL
  CANCELLED
  ENDED
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
  CANCELLED
  ABSENT
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PRO
}

enum PostType {
  ANNOUNCEMENT
  SHARE
  PHOTO
}

enum NotificationType {
  SYSTEM
  ACTIVITY
  INTERACTION
  INVITE
  BROADCAST
}

enum ReportReason {
  SPAM
  VIOLENCE
  INAPPROPRIATE_CONTENT
  HARASSMENT
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED
}

// ─────────────────────────────────────────────
// User
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  lineUserId   String?  @unique
  phone        String?
  avatar       String?
  bio          String?

  // XP Systems
  globalXP     Int      @default(0)
  sportXP      Json     @default("{}") // Stores { "BADMINTON": 500, "HIKING": 20 }

  // User Preferences
  exploreTags  Json     @default("[]") // Stores ExploreTag[] for cross-device sync

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  hostedActivities Activity[]     @relation("UserHostedActivities")
  registrations    Registration[]
  clubMemberships  ClubMember[]
  clubAdminRoles   ClubAdmin[]
  posts            Post[]
  postLikes        PostLike[]
  comments         Comment[]
  notifications    Notification[]
  refreshTokens    RefreshToken[]

  // Ratings
  activityRatings  ActivityRating[]

  // Safety
  reportsSent      Report[]       @relation("Reporter")
  reportsReceived  Report[]       @relation("ReportTarget")
  blacklist        Blacklist[]    @relation("Blocker")
  blockedBy        Blacklist[]    @relation("Blocked")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// Club
// ─────────────────────────────────────────────

model Club {
  id          String   @id @default(cuid())
  name        String
  logo        String?
  coverImage  String?
  rating      Float    @default(0)
  description String
  tags        String[]
  city        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activities  Activity[]
  members     ClubMember[]
  admins      ClubAdmin[]
  posts       Post[]
  inviteLinks ClubInviteLink[]

  @@map("clubs")
}

model ClubMember {
  userId        String
  clubId        String
  joinedAt      DateTime @default(now())
  activityCount Int      @default(0) // Contribution to this club

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@id([userId, clubId])
  @@map("club_members")
}

model ClubAdmin {
  userId String
  clubId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@id([userId, clubId])
  @@map("club_admins")
}

model ClubInviteLink {
  id              String   @id @default(cuid())
  clubId          String
  token           String   @unique
  expiresAt       DateTime
  requireApproval Boolean  @default(false)
  createdAt       DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@map("club_invite_links")
}

// ─────────────────────────────────────────────
// Activity
// ─────────────────────────────────────────────

model Activity {
  id                   String           @id @default(cuid())
  hostId               String
  clubId               String?          // Optional for personal activities
  title                String
  primarySport         PrimarySport
  date                 DateTime
  time                 String
  location             String
  city                 String
  price                Int              @default(0)
  mode                 RegistrationMode
  approvalMode         ApprovalMode     @default(AUTO)
  status               ActivityStatus   @default(OPEN)
  maxParticipants      Int?
  currentAppCount      Int              @default(0) // Count of APPROVED registrations
  minCancelHours       Int              @default(24)
  groups               String[]
  level                Level
  image                String?
  description          String
  tags                 String[]
  lat                  Float?
  lng                  Float?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  host          User             @relation("UserHostedActivities", fields: [hostId], references: [id])
  club          Club?            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  registrations Registration[]
  ratings       ActivityRating[]

  @@map("activities")
}

model Registration {
  id             String             @id @default(cuid())
  userId         String
  activityId     String
  status         RegistrationStatus @default(PENDING)
  
  // Logistics & Contact
  contactMethod  String             // Line ID, Phone, etc.
  realName       String
  group          String?            // For OPEN mode
  transportation String?            // driver, passenger, self
  carCapacity    Int?               // If driver
  
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
  @@map("registrations")
}

// ─────────────────────────────────────────────
// Safety & Social
// ─────────────────────────────────────────────

model Blacklist {
  id            String   @id @default(cuid())
  hostId        String   // Blocker
  blockedUserId String   // Blocked
  createdAt     DateTime @default(now())

  host        User @relation("Blocker", fields: [hostId], references: [id], onDelete: Cascade)
  blockedUser User @relation("Blocked", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([hostId, blockedUserId])
  @@map("blacklist")
}

model ActivityRating {
  id         String   @id @default(cuid())
  activityId String
  userId     String
  score      Int      // 1–5
  comment    String?
  createdAt  DateTime @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
  @@map("activity_ratings")
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  targetId   String       // User ID, Post ID, or Message ID
  targetType String       // "USER", "POST", "MESSAGE"
  reason     ReportReason
  content    String?
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())

  reporter User @relation("Reporter", fields: [reporterId], references: [id])
  target   User @relation("ReportTarget", fields: [targetId], references: [id]) // Assuming target is often a user

  @@map("reports")
}

// ─────────────────────────────────────────────
// Post, Comment, Notification
// ─────────────────────────────────────────────

model Post {
  id        String   @id @default(cuid())
  clubId    String
  authorId  String
  type      PostType
  content   String
  images    String[] // Max 10
  likes     Int      @default(0)
  comments  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club     Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postLikes PostLike[]
  postComments Comment[]

  @@map("posts")
}

model PostLike {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@map("post_likes")
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?
  content   String
  createdAt DateTime @default(now())

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@map("comments")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  content   String
  isRead    Boolean          @default(false)
  
  // For Broadcasts/Rich Notifications
  image     String?
  lat       Float?
  lng       Float?
  
  linkId    String?
  linkType  String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
